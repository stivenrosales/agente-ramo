# Copy this file to .env and fill with real values:
#   cp env.example .env

# === LLM (OpenRouter) ===
OPENROUTER_API_KEY=

# === Chatwoot ===
# Base URL of your Chatwoot instance (cloud or self-hosted). No trailing slash.
CHATWOOT_BASE_URL=https://app.chatwoot.com
# Account ID — the number in .../app/accounts/{ACCOUNT_ID}/...
CHATWOOT_ACCOUNT_ID=
# User Access Token (Profile → Access Token) OR Agent Bot token.
# NEVER commit this to git. Set it as an env var in EasyPanel.
CHATWOOT_API_TOKEN=
# Optional: comma-separated inbox IDs the bot should respond on.
# Leave empty to respond to ALL inboxes that hit the webhook.
CHATWOOT_INBOX_IDS=
# Optional: comma-separated Chatwoot contact IDs allowed (testing allowlist).
# Leave empty to allow all senders.
CHATWOOT_ALLOWED_SENDER_IDS=

# === Postgres (must support SSL in prod) ===
DATABASE_URL=postgres://user:pass@host:5432/dbname

# === Google Service Account (base64 encoded full JSON) ===
# Generate with: base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_B64=

# === Fitness Space ERP API keys (e-admin.mx) ===
FS_ERP_KEY_TAXQUENA=
FS_ERP_KEY_LAS_TORRES=
FS_ERP_KEY_ERMITA=
FS_ERP_KEY_PLUTARCO=
FS_ERP_KEY_JIUTEPEC=

# === Fitness Space Google Calendar IDs ===
FS_CALENDAR_ID_TAXQUENA=
FS_CALENDAR_ID_LAS_TORRES=
FS_CALENDAR_ID_ERMITA=
FS_CALENDAR_ID_PLUTARCO=
FS_CALENDAR_ID_JIUTEPEC=

# === Webhook shared secret ===
# If set, incoming webhooks MUST include header "X-Webhook-Secret: <value>"
# (or "X-Chatwoot-Secret"). Configure the same value in the Chatwoot webhook config.
# Leave empty to disable (NOT recommended in production).
WEBHOOK_SECRET=

# === Server ===
PORT=3000
NODE_ENV=production
