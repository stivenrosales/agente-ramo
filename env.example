# Copy este archivo a .env y completa los valores reales:
#   cp env.example .env

# === LLM (OpenRouter) ===
OPENROUTER_API_KEY=

# === Chatwoot ===
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=
CHATWOOT_INBOX_IDS=
CHATWOOT_ALLOWED_SENDER_IDS=

# === Postgres ===
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Opcional: DATABASE_SSL=disable | no-verify | require (default: disable)

# === Microsoft / Outlook ===
# Todas opcionales. Mientras estén vacías, el bot SIMULA el agendamiento
# (responde al cliente como si hubiera reservado pero no crea evento real).
# Apenas IT de Ramo entregue las credenciales, se llenan estas 4 y el modo real
# se activa automáticamente sin tocar código.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_CALENDAR_MAILBOX=

# === Reglas de negocio Ramo (Lima, GMT-5) ===
RAMO_TIMEZONE=America/Lima
RAMO_BUSINESS_HOURS=09:00-18:00
RAMO_LUNCH_BLOCK=12:00-14:00
RAMO_BUSINESS_DAYS=1,2,3,4,5
RAMO_BOOKING_DURATION_MIN=60
RAMO_DEFAULT_MEETING_PLATFORM=teams
RAMO_OFFICE_ADDRESS=Av. Aviación 2405, San Borja 15063, Lima

# === Webhook shared secret ===
WEBHOOK_SECRET=

# === Server ===
PORT=3000
NODE_ENV=production
